   "source": [
    "### Step 8: Upload a PDF and Start Interactive Q&A Session\n",
    "Running this cell will prompt you to upload a file (in Google Colab) or input a file path (locally in VS Code). It will index the PDF and launch the interactive Q&A session routing queries dynamically."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import re\n",
    "import fitz\n",
    "import config\n",
    "from retriever import SimpleInMemoryVectorStore, Document\n",
    "from self_rag import SelfRAGPipeline\n",
    "import vision_vlm\n",
    "\n",
    "# Check if running in Google Colab\n",
    "is_colab = False\n",
    "try:\n",
    "    import google.colab\n",
    "    is_colab = True\n",
    "except ImportError:\n",
    "    pass\n",
    "\n",
    "pdf_filename = \"\"\n",
    "if is_colab:\n",
    "    print(\"--- Google Colab Environment ---\")\n",
    "    print(\"Please upload a PDF document for analysis (or cancel upload to use the default test_document.pdf):\")\n",
    "    from google.colab import files\n",
    "    uploaded = files.upload()\n",
    "    if uploaded:\n",
    "        pdf_filename = list(uploaded.keys())[0]\n",
    "        print(f\"File uploaded successfully: {pdf_filename}\")\n",
    "    else:\n",
    "        print(\"No file uploaded. Using default test_document.pdf.\")\n",
    "        pdf_filename = \"test_document.pdf\"\n",
    "else:\n",
    "    print(\"--- Local Jupyter Environment ---\")\n",
    "    pdf_filename = input(\"Enter the path to your local PDF file (or press Enter to use test_document.pdf): \").strip()\n",
    "    if not pdf_filename:\n",
    "        pdf_filename = \"test_document.pdf\"\n",
    "        \n",
    "if not os.path.exists(pdf_filename):\n",
    "    print(f\"Creating default document '{pdf_filename}' since none was provided...\")\n",
    "    import test_vlm\n",
    "    test_vlm.create_sample_pdf(pdf_filename)\n",
    "\n",
    "print(f\"\\nIngesting and Indexing PDF: '{pdf_filename}'...\")\n",
    "store = SimpleInMemoryVectorStore()\n",
    "doc = fitz.open(pdf_filename)\n",
    "docs = []\n",
    "for page_num in range(len(doc)):\n",
    "    text = doc[page_num].get_text()\n",
    "    if text.strip():\n",
    "        docs.append(Document(\n",
    "            page_content=text,\n",
    "            metadata={\"source\": pdf_filename, \"page\": page_num + 1}\n",
    "        ))\n",
    "store.add_documents(docs)\n",
    "doc.close()\n",
    "print(f\"Indexed {len(store.documents)} pages successfully.\\n\")\n",
    "\n",
    "pipeline = SelfRAGPipeline(store)\n",
    "\n",
    "print(\"=======================================================\")\n",
    "print(\"OmniBrain Interactive Q&A Session Started!\")\n",
    "print(\"Ask a question (e.g., 'What is the revenue on page 1?' or textual questions).\")\n",
    "print(\"Type 'exit' to end the session.\")\n",
    "print(\"=======================================================\")\n",
    "\n",
    "while True:\n",
    "    query = input(\"\\nAsk a question: \").strip()\n",
    "    if not query:\n",
    "        continue\n",
    "    if query.lower() == \"exit\":\n",
    "        print(\"Ending Q&A Session. Goodbye!\")\n",
    "        break\n",
    "        \n",
    "    # Determine Routing (Visual vs Text RAG)\n",
    "    visual_keywords = [\"chart\", \"table\", \"graph\", \"figure\", \"visual\", \"image\", \"diagram\", \"page\"]\n",
    "    is_visual = any(kw in query.lower() for kw in visual_keywords)\n",
    "    \n",
    "    if is_visual:\n",
    "        # Router: find target page number\n",
    "        page_match = re.search(r'page\\s*(\d+)', query.lower())\n",
    "        target_page = None\n",
    "        if page_match:\n",
    "            target_page = int(page_match.group(1)) - 1\n",
    "            print(f\"--> Router: Query references page {target_page + 1}. Routing to Vision Agent.\")\n",
    "        else:\n",
    "            for doc_obj in store.documents:\n",
    "                content_lower = doc_obj.page_content.lower()\n",
    "                if \"table\" in content_lower or \"figure\" in content_lower or \"chart\" in content_lower:\n",
    "                    target_page = doc_obj.metadata.get(\"page\", 1) - 1\n",
    "                    break\n",
    "            if target_page is None:\n",
    "                target_page = 0\n",
    "            print(f\"--> Router: Visual keyword matched. Selecting page {target_page + 1}. Routing to Vision Agent.\")\n",
    "            \n",
