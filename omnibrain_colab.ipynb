  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 3: Define Configurations\n",
    "Locking active provider to exclusively Google Gemini."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Write config file programmatically\n",
    "config_code = \"\"\"\n",
    "import os\n",
    "OPENAI_API_KEY = os.getenv(\"OPENAI_API_KEY\", \"\")\n",
    "GEMINI_API_KEY = os.getenv(\"GEMINI_API_KEY\", \"\")\n",
    "DEFAULT_PROVIDER = \"gemini\"\n",
    "\n",
    "MODELS = {\n",
    "    \"openai\": {\n",
    "        \"vlm\": \"gpt-4o\",\n",
    "        \"llm\": \"gpt-4o-mini\",\n",
    "        \"embed\": \"text-embedding-3-small\"\n",
    "    },\n",
    "    \"gemini\": {\n",
    "        \"vlm\": \"gemini-2.5-flash\",\n",
    "        \"llm\": \"gemini-2.5-flash\",\n",
    "        \"embed\": \"text-embedding-004\"\n",
    "    }\n",
    "}\n",
    "MAX_SELF_RAG_RETRIES = 3\n",
    "def get_vlm_model(provider=None):\n",
    "    prov = provider or DEFAULT_PROVIDER\n",
    "    return MODELS[prov][\"vlm\"]\n",
    "def get_llm_model(provider=None):\n",
    "    prov = provider or DEFAULT_PROVIDER\n",
    "    return MODELS[prov][\"llm\"]\n",
    "def get_embed_model(provider=None):\n",
    "    prov = provider or DEFAULT_PROVIDER\n",
    "    return MODELS[prov][\"embed\"]\n",
    "def get_api_key(provider=None):\n",
    "    prov = provider or DEFAULT_PROVIDER\n",
    "    return GEMINI_API_KEY if prov == \"gemini\" else OPENAI_API_KEY\n",
    "def print_status():\n",
    "    print(\"--- OmniBrain Configuration ---\")\n",
    "    print(f\"Default Provider: {DEFAULT_PROVIDER.upper()}\")\n",
    "    print(f\"Gemini Key Set: {'Yes' if GEMINI_API_KEY else 'No'}\")\n",
    "    print(\"-------------------------------\")\n",
    "\"\"\"\n",
    "with open(\"config.py\", \"w\") as f:\n",
    "    f.write(config_code.strip())\n",
    "import config\n",
    "config.print_status()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 4: Define VLM Vision Extraction Module\n",
    "This renders pages from a PDF and calls VLM models with a target Pydantic schema for structured output."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "vlm_code = \"\"\"\n",
    "import base64\n",
    "import io\n",
    "import json\n",
    "from typing import List, Dict, Any, Optional, Literal\n",
    "import fitz\n",
    "from pydantic import BaseModel, Field\n",
    "import config\n",
    "\n",
    "class VisualExtraction(BaseModel):\n",
    "    type: Literal[\"chart\", \"table\", \"diagram\", \"other\"]\n",
    "    description: str\n",
    "    extracted_values: List[Dict[str, Any]]\n",
    "    axis_labels: Optional[List[str]] = None\n",
    "\n",
    "def image_to_base64(image_bytes: bytes) -> str:\n",
    "    return base64.b64encode(image_bytes).decode(\"utf-8\")\n",
    "\n",
    "def render_pdf_page_to_bytes(pdf_path: str, page_number: int, dpi: int = 150) -> bytes:\n",
    "    doc = fitz.open(pdf_path)\n",
    "    page = doc.load_page(page_number)\n",
    "    zoom = dpi / 72.0\n",
    "    mat = fitz.Matrix(zoom, zoom)\n",
    "    pix = page.get_pixmap(matrix=mat, alpha=False)\n",
    "    png_bytes = pix.tobytes(\"png\")\n",
    "    doc.close()\n",
    "    return png_bytes\n",
    "\n",
    "def analyze_visual_element(image_bytes: bytes, provider: Optional[str] = None) -> VisualExtraction:\n",
    "    selected_provider = provider or config.DEFAULT_PROVIDER\n",
    "    api_key = config.get_api_key(selected_provider)\n",
    "    vlm_model = config.get_vlm_model(selected_provider)\n",
    "    base64_img = image_to_base64(image_bytes)\n",
    "    \n",
    "    if not api_key:\n",
    "        return get_mock_extraction()\n",
    "        \n",
    "    from langchain_core.messages import HumanMessage\n",
    "    system_prompt = \"Extract visual tables/charts content and return strictly structured JSON.\"\n",
    "    msg = HumanMessage(content=[\n",
    "        {\"type\": \"text\", \"text\": system_prompt},\n",
    "        {\"type\": \"image_url\", \"image_url\": {\"url\": f\"data:image/png;base64,{base64_img}\"}}\n",
    "    ])\n",
    "    \n",
    "    if selected_provider == \"gemini\":\n",
    "        from langchain_google_genai import ChatGoogleGenerativeAI\n",
    "        llm = ChatGoogleGenerativeAI(model=vlm_model, google_api_key=api_key, temperature=0.0)\n",
    "    else:\n",
    "        from langchain_openai import ChatOpenAI\n",
    "        llm = ChatOpenAI(model=vlm_model, api_key=api_key, temperature=0.0)\n",
    "        \n",
    "    try:\n",
    "        structured_llm = llm.with_structured_output(VisualExtraction)\n",
    "        return structured_llm.invoke([msg])\n",
    "    except Exception:\n",
    "        return get_mock_extraction()\n",
    "\n",
    "def get_mock_extraction() -> VisualExtraction:\n",
    "    return VisualExtraction(\n",
    "        type=\"chart\",\n",
    "        description=\"[MOCK DATA] A line chart showing corporate revenue trends between 2022 and 2024.\",\n",
    "        extracted_values=[\n",
    "            {\"Year\": 2022, \"Revenue_Millions\": 2.0},\n",
    "            {\"Year\": 2023, \"Revenue_Millions\": 3.5},\n",
    "            {\"Year\": 2024, \"Revenue_Millions\": 5.0}\n",
    "        ],\n",
    "        axis_labels=[\"Year\", \"Revenue_Millions\"]\n",
    "    )\n",
    "\"\"\"\n",
    "with open(\"vision_vlm.py\", \"w\") as f:\n",
    "    f.write(vlm_code.strip())\n",
    "print(\"vision_vlm.py written.\")"
   ]
  },
