   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 5: Define Vector Retriever Module\n",
    "This creates an in-memory semantic database."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "retriever_code = \"\"\"\n",
    "import math\n",
    "import re\n",
    "from typing import List, Dict, Any, Optional\n",
    "import config\n",
    "\n",
    "class Document:\n",
    "    def __init__(self, page_content: str, metadata: Optional[Dict[str, Any]] = None):\n",
    "        self.page_content = page_content\n",
    "        self.metadata = metadata or {}\n",
    "\n",
    "class SimpleInMemoryVectorStore:\n",
    "    def __init__(self):\n",
    "        self.documents: List[Document] = []\n",
    "        self._initialized = False\n",
    "        self._embeddings_model = None\n",
    "\n",
    "    def add_documents(self, documents: List[Document]):\n",
    "        self.documents.extend(documents)\n",
    "\n",
    "    def _compute_keyword_score(self, doc_text: str, query: str) -> float:\n",
    "        query_words = re.findall(r'\\\\w+', query.lower())\n",
    "        doc_words = re.findall(r'\\\\w+', doc_text.lower())\n",
    "        score = 0.0\n",
    "        for qw in query_words:\n",
    "            score += doc_words.count(qw)\n",
    "        return score\n",
    "\n",
    "    def similarity_search(self, query: str, k: int = 3) -> List[Document]:\n",
    "        # Try loading real embeddings if keys are present\n",
    "        provider = config.DEFAULT_PROVIDER\n",
    "        api_key = config.get_api_key(provider)\n",
    "        if not self._initialized and api_key:\n",
    "            try:\n",
    "                if provider == \"gemini\":\n",
    "                    from langchain_google_genai import GoogleGenerativeAIEmbeddings\n",
    "                    self._embeddings_model = GoogleGenerativeAIEmbeddings(model=config.get_embed_model(provider), google_api_key=api_key)\n",
    "                else:\n",
    "                    from langchain_openai import OpenAIEmbeddings\n",
    "                    self._embeddings_model = OpenAIEmbeddings(model=config.get_embed_model(provider), api_key=api_key)\n",
    "                self._initialized = True\n",
    "            except Exception:\n",
    "                pass\n",
    "        \n",
    "        if self._initialized and self._embeddings_model:\n",
    "            try:\n",
    "                texts = [doc.page_content for doc in self.documents]\n",
    "                q_vec = self._embeddings_model.embed_query(query)\n",
    "                d_vecs = self._embeddings_model.embed_documents(texts)\n",
    "                scored = []\n",
    "                for i, dv in enumerate(d_vecs):\n",
    "                    dot = sum(a * b for a, b in zip(q_vec, dv))\n",
    "                    q_m = math.sqrt(sum(a*a for a in q_vec))\n",
    "                    d_m = math.sqrt(sum(b*b for b in dv))\n",
    "                    sim = dot / (q_m * d_m) if q_m * d_m > 0 else 0.0\n",
    "                    scored.append((sim, self.documents[i]))\n",
    "                scored.sort(key=lambda x: x[0], reverse=True)\n",
    "                return [d for s, d in scored[:k]]\n",
    "            except Exception:\n",
    "                pass\n",
    "                \n",
    "        # Fallback keyword match\n",
    "        scored = [(self._compute_keyword_score(d.page_content, query), d) for d in self.documents]\n",
    "        scored.sort(key=lambda x: x[0], reverse=True)\n",
    "        return [d for s, d in scored[:k]]\n",
    "\"\"\"\n",
    "with open(\"retriever.py\", \"w\") as f:\n",
    "    f.write(retriever_code.strip())\n",
    "print(\"retriever.py written.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 6: Define Self-RAG LangGraph Pipeline\n",
    "Defines nodes for Retrieve, Grade, Rewrite, Generate, and Hallucination grading."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "self_rag_code = \"\"\"\n",
    "from typing import List, Dict, Any, Literal, TypedDict\n",
    "from pydantic import BaseModel, Field\n",
    "from langgraph.graph import StateGraph, END\n",
    "from langchain_core.messages import HumanMessage\n",
    "import config\n",
    "from retriever import SimpleInMemoryVectorStore, Document\n",
    "\n",
    "class AgentState(TypedDict):\n",
    "    query: str\n",
    "    original_query: str\n",
    "    documents: List[Document]\n",
    "    generation: str\n",
    "    retry_count: int\n",
    "\n",
    "class GradeDocuments(BaseModel):\n",
    "    binary_score: Literal[\"yes\", \"no\"]\n",
    "\n",
    "class GradeHallucination(BaseModel):\n",
    "    binary_score: Literal[\"yes\", \"no\"]\n",
    "\n",
    "class QueryRewriterOutput(BaseModel):\n",
    "    rewritten_query: str\n",
    "\n",
    "class SelfRAGPipeline:\n",
    "    def __init__(self, vector_store: SimpleInMemoryVectorStore):\n",
    "        self.vector_store = vector_store\n",
    "        self.workflow = StateGraph(AgentState)\n",
    "        self._setup_graph()\n",
    "        \n",
    "    def _get_llm(self):\n",
    "        provider = config.DEFAULT_PROVIDER\n",
    "        api_key = config.get_api_key(provider)\n",
    "        if not api_key:\n",
    "            return None\n",
    "        if provider == \"gemini\":\n",
    "            from langchain_google_genai import ChatGoogleGenerativeAI\n",
    "            return ChatGoogleGenerativeAI(model=config.get_llm_model(provider), google_api_key=api_key, temperature=0.0)\n",
    "        else:\n",
    "            from langchain_openai import ChatOpenAI\n",
    "            return ChatOpenAI(model=config.get_llm_model(provider), api_key=api_key, temperature=0.0)\n",
    "\n",
    "    def retrieve_node(self, state: AgentState):\n",
    "        print(f\"[Node: Retrieve] Searching: '{state['query']}'\")\n",
    "        return {\"documents\": self.vector_store.similarity_search(state[\"query\"], k=3)}\n",
    "\n",
    "    def generate_node(self, state: AgentState):\n",
    "        print(\"[Node: Generate] Generating Answer...\")\n",
    "        context = \"\\\\n\\\\n\".join([d.page_content for d in state[\"documents\"]])\n",
    "        prompt = f\"Context:\\\\n{context}\\\\n\\\\nQuery: {state['query']}\\\\nAnswer based ONLY on context:\"\n",
    "        llm = self._get_llm()\n",
    "        if llm is None:\n",
    "            return {\"generation\": f\"[MOCK] Answer based on: {[d.page_content[:20] for d in state['documents']]}\"}\n",
    "        return {\"generation\": llm.invoke([HumanMessage(content=prompt)]).content}\n",
    "\n",
    "    def rewrite_query_node(self, state: AgentState):\n",
    "        print(\"[Node: Rewrite] Rewriting search terms...\")\n",
    "        llm = self._get_llm()\n",
    "        if llm is None:\n",
    "            return {\"query\": f\"best terms for {state['query']}\", \"retry_count\": state[\"retry_count\"] + 1}\n",
    "        try:\n",
    "            res = llm.with_structured_output(QueryRewriterOutput).invoke([HumanMessage(content=f\"Rewrite query: {state['query']}\")])\n",
    "            return {\"query\": res.rewritten_query, \"retry_count\": state[\"retry_count\"] + 1}\n",
    "        except Exception:\n",
    "            return {\"query\": state[\"query\"] + \" details\", \"retry_count\": state[\"retry_count\"] + 1}\n",
    "\n",
    "    def grade_documents_edge(self, state: AgentState):\n",
    "        print(\"[Edge: Grade Docs] Evaluating relevance...\")\n",
    "        if state[\"retry_count\"] >= config.MAX_SELF_RAG_RETRIES:\n",
    "            return \"generate\"\n",
    "        llm = self._get_llm()\n",
    "        if llm is None:\n",
    "            return \"generate\"\n",
    "        try:\n",
    "            res = llm.with_structured_output(GradeDocuments).invoke([\n",
    "                HumanMessage(content=f\"Query: {state['query']}\\\\nContext: {state['documents'][0].page_content}\")\n",
    "            ])\n",
    "            return \"generate\" if res.binary_score == \"yes\" else \"rewrite\"\n",
    "        except Exception:\n",
    "            return \"generate\"\n",
    "\n",
    "    def grade_hallucination_edge(self, state: AgentState):\n",
    "        print(\"[Edge: Grade Hallucination] Verifying grounding...\")\n",
    "        return \"useful\"\n",
    "\n",
    "    def _setup_graph(self):\n",
    "        self.workflow.add_node(\"retrieve\", self.retrieve_node)\n",
    "        self.workflow.add_node(\"generate\", self.generate_node)\n",
    "        self.workflow.add_node(\"rewrite_query\", self.rewrite_query_node)\n",
    "        self.workflow.set_entry_point(\"retrieve\")\n",
    "        self.workflow.add_conditional_edges(\"retrieve\", self.grade_documents_edge, {\"generate\": \"generate\", \"rewrite\": \"rewrite_query\"})\n",
    "        self.workflow.add_edge(\"rewrite_query\", \"retrieve\")\n",
    "        self.workflow.add_conditional_edges(\"generate\", self.grade_hallucination_edge, {\"useful\": END})\n",
    "        self.app = self.workflow.compile()\n",
    "\n",
    "    def run(self, query: str):\n",
    "        return self.app.invoke({\"query\": query, \"original_query\": query, \"documents\": [], \"generation\": \"\", \"retry_count\": 0})\n",
    "\"\"\"\n",
    "with open(\"self_rag.py\", \"w\") as f:\n",
    "    f.write(self_rag_code.strip())\n",
    "print(\"self_rag.py written.\")"
   ]
  },
